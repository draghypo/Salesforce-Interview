  Process of subscribing platform event: - 
*************************************************
        There are 3 ways through we can subscribe the platform event.

                1). Flow
                2). Apex Trigger
                3). LWC

            1). Flow: - create platform event triggerd flow and select the platform event which you have and perform the 
                        operation what do you want in the flow.
            2). Apex Trigger: - need to write the trigger on platform event only support after insert.

                          trigger SubscribePlatformEvent on Order_Detail__e (after insert) {
                              if(Trigger.isAfter && Trigger.isInsert) {
                                  createTask(Trigger.new);
                              }
                              
                              public static void createTask(List<Order_Detail__e> orderDetails) {
                                  List<Task> tas = new List<Task>();
                                  for(Order_Detail__e event : orderDetails) {
                                      tas.add(new Task(subject = 'subscribed from the apex trigger', description = 'orderId = '+event.Order_Number__c));
                                  }
                                  insert tas;
                              }
                          }

          3). LWC : - through lightning/empApi .

                Syntax: - import { subscribe, unsubscribe, onError, isEmpEnabled } from 'lightning/empApi';

                Js code
              ----------

                  import { LightningElement } from 'lwc';
                  import { subscribe } from 'lightning/empApi';
                  
                  export default class LattestAccountWithoutRefresh extends LightningElement {
                      channelName = '/event/Order_Detail__e';  // replace your platform event name, if cdc add '/data/AccountChangeEvent' instead of event add data.
                  
                      connectedCallback() {
                          this.startListening();
                      }
                  
                      // Step 2: Establishes the handshake connection with Salesforce
                      startListening() {
                          // .bind(this) ensures 'this' inside the callback still refers to our LWC component
                          subscribe(this.channelName, -1, this.handleNotification.bind(this)) // -1 is current replay ID
                              .then(response => {
                                  console.log('Successfully subscribed to channel: ', response.channel);
                              });
                      }
                  
                      // Step 4: Sits completely idle, firing ONLY when a live event arrives
                      handleNotification(eventData) {
                          console.log('--- New Platform Event Received ---');
                          console.log('Full Payload Object: ', JSON.stringify(eventData.data.payload));
                          // console.log('Order Number: ', eventData.data.payload.Order_Number__c);
                      }
                  }





      Database.RaisesPlatformEvent
*********************************************

      Database.RaisesPlatformEvent: - It is a marker interface does not have any method to overrid. this interface is used in
                                      batch class to know the details of batch failure.need to implement the interface it will
                                      let you know the if any exception come in the batch, it will fire the BatchApexErrorEvent
                                      platform event so you can capture when batch failed , batchname ,job id etc.

        syntax : - global class LoyaltyPointsBatch implements Database.Batchable<sObject>, Database.RaisesPlatformEvent {
                        start();execute();finish(); }
                  // if any exception come in the batch it will fire the standard platformevent "BatchApexErrorEvent"

                  Now manually need to write a trigger on standard plarform event on "BatchApexErrorEvent"

                    trigger GenericBatchErrorTrigger on BatchApexErrorEvent (after insert) {
                        Set<Id> jobIds = new Set<Id>();
                            for (BatchApexErrorEvent event : Trigger.new) {
                            if (event.AsyncApexJobId != null) {
                                jobIds.add(event.AsyncApexJobId);
                            }
                        }
                        Map<Id, AsyncApexJob> jobMap = new Map<Id, AsyncApexJob>([SELECT Id, ApexClass.Name FROM AsyncApexJob    WHERE Id IN :jobIds]);
                        
                        for (BatchApexErrorEvent event : Trigger.new) {
                            String className = 'Unknown Batch Class';
                            if (jobMap.containsKey(event.AsyncApexJobId)) {
                                className = jobMap.get(event.AsyncApexJobId).ApexClass.Name;
                            }
                            
                            System.debug('🚨🚨🚨 [BATCH APEX FAILURE DETECTED] 🚨🚨🚨');
                            System.debug('Batch Class Name : ' + className);
                            System.debug('Async Job ID     : ' + event.AsyncApexJobId);
                            System.debug('Error Message    : ' + event.Message);
                            System.debug('Stack Trace      : ' + event.StackTrace);
                            System.debug('Failed Scope IDs : ' + event.JobScope); 
                            System.debug('--------------------------------------------------');
                        }
                    }
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
