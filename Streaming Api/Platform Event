Handler class to know the publish successful or fail based on creating a task.
----------------------------------------------------------------------------------
                public class P_PlatformEventHandler_callback implements EventBus.EventPublishSuccessCallback, EventBus.EventPublishFailureCallback {
                    public void onSuccess(EventBus.successResult result) { // method of EventBus.EventPublishSuccessCallback interface
                        List<String> uUiD = result.getEventUuids();  // know the uuid.
                        createTaskforEvent(uUiD, True);
                    }
                    public void onFailure(EventBus.failureResult result) { // method of EventBus.EventPublishFailureCallback interface
                        List<String> uUiD = result.getEventUuids();
                        createTaskforEvent(uUiD, false);
                    }
                    public void createTaskforEvent(List<String> uUids, Boolean isSucess) {
                        String uUIdsString;
                        for(String uId : uUids) {
                            uUIdsString = uUIdsString+uId;
                        }
                        Task tas = new Task();
                        if(isSucess) {
                            tas.subject = 'Platform event publish successfully.';
                            tas.Description = 'Total platform event publish' + uUids.size() + '-' + uUids;
                        }
                        else {
                 			tas.subject = 'Platform event published failed';
                            tas.Description = 'Total platform event publish'+uUids.size();
                        }
                        try{
                          insert tas;  
                        }
                        catch(Exception e) {
                            System.debug('Exception occured='+e.getMessage());
                        }
                    }
                }
